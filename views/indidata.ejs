<% layout('/const/boilerplate') -%>
<body>
    <h5 class="card_indidata_title"><%= indiData.title %> </h5>

    <div class="row-md-10 col-md-10 offset-md-4 card_indidata">
	<div class="col-12 col-md-5">
	    <img src="<%= indiData.image.url %>"class="img-fluid"alt="image">
	</div>
	<h6 id="card_indidata_price">&#8377;<%= indiData.price.toLocaleString("en-EN") %>/night </h6>
	<div class="card_indidata_text">
	    <p>
	    <%= indiData.location %><br>
	    <%= indiData.country%><br>
	    </p>
	</div>
    </div>
    <div class=" mt-1 ">
	<p id="card_indidata_description">
	<%= indiData.description %>
	</p>
    </div>
    <div class="indidata_btns">
	<form action="/listings/<%= indiData.id %>?_method=DELETE" class="delete_btn" method="post">
	    <button class="btn btn-dark custom-btn-size custom-btn-color">Delete</button>
	</form>
	<form action="/listings/<%= indiData.id %>/edit" class="edit_btn" method="get"> 
	    <button class="btn btn-dark custom-btn-size custom-btn-color">Edit</button>
	</form>
    </div>
    <hr>
    <div class="Review-box row-md-10 col-md-10 offset-md-1 mt-3 mb-3">
	<h4>Write a review!</h4>
	<form action="/listings/<%= indiData.id %>/reviews" method="POST" novalidate class="needs-validation" >
	    <label for="ratings" class="form-label">Rate us here!</label>
	    <div class="col-md-9 offset-1">
		<input type="range" name="review[ratings]" id="ratings" class="form-range" min="1" max="5">
	    </div>
	    <div>
		<label for="comments" class="form-label">Add your comment here</label>
		<textarea name="review[comments]" id= "comments" row="3" col="45"width:"75%" class="form-control"    required>
		</textarea>
		<div class="invalid-feedback">
		    Please leave a comment!!
		</div>
	    </div>
	    <button class="btn btn-outline-dark mt-3" >Post</button>
	</form>
	<hr>
	<p><b>All Reviews</b></p>
	<div class="row">
	    <% for(let review of indiData.reviews) { %>
	    <div class="card col-5 ms-3 mt-3">
		<div class="card-body ">
		    <h6 class="class-title"><b>John Doe</b></h6>
		    <p class="card-text"><%= review.comments %></p>
		    <p class="card-text"><%= review.ratings%> stars</p>
		</div>
		<form action="/listings/<%= indiData.id %>/reviews/editReview/<%= review.id %>" method="GET">
		    <button class="btn btn-outline-dark mb-1">Edit</button>
		</form>
	    </div>
	    <% } %>
	</div>
    </div>
</body>
