<% layout('./const/boilerplate') -%>
<body>
	<h3>All Listings </h3>
	    <div class="card_container">
	<% for(let data of listings){ %>
	<a href="/listings/<%= data.id %>" class="card_click">
	    <div class="cards">
		 <img src="<%= data.image.url %>" alt="img" class="card_img">
		<div class="card_text"> 
		<p><b><%= data.title%></b><br>
		&#8377;<%= data.price.toLocaleString("en-IN") %>/night<br>
		<%= data.location %></p>
		</div>
	    </div>
	</a>
	    <% } %>	
	    </div>
</body>
