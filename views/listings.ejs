<% layout('./const/boilerplate') -%>
<body>
	<% for(let data of result){ %>
	    <div>
	    <img src="<%= data.image.url %>" alt="img">
	    <h3><%= data.title%></h3>
	    </div>
	    <a href="/listings/<%= data.id %>">tap here for  more info!</a>
	    &nbsp;&nbsp;&nbsp;
	    <a href="/listings/<%= data.id %>/edit">Update details</a>
	<form action="/listings/<%= data.id %>?_method=DELETE" method="post">
	    <button type="submit" >Delete</button>
	</form>
	<hr><hr>
	    <% } %>	
</body>
