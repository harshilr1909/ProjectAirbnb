<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Airbnb</title>
</head>
<body>
	<form action="/listings" method="post">
	    <label for="title">Title:</label>
	    <input type="text" name="title" id="title" >
	    <br>
	    <label for="price">price:</label>
