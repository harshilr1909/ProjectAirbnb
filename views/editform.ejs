<% layout('/const/boilerplate') -%> 
<body>
	<form action="/listings?_method=PATCH" method="post">
	    <label for="title">Title:</label>
	    <input type="text" name="title" id="title" value="<%= result.title%>">
	    <br>
	    <label for="price">price:</label>
	    <input type="text" name="price" id="price" value="<%= result.price %>">
	    <br>
	    <label for="location">location:</label>
	    <input type="text" name="location" id="location" value="<%= result.location %>">
	    <br>
	    <label for="country">country:</label>
	    <input type="text" name="country" id="country" value="<%= result.country%>">
	    <br>
	    <label for="description">description:</label>
	    <textarea name="description" id="description"><%= result.description %></textarea>
	    <br>
	    <button>Update</button>
	</form>
	
